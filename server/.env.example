# Prisma Postgres connection string
DATABASE_URL=

# Server port (defaults to 3000)
PORT=3000

# Required: secret for signing staff JWTs. Generate a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Optional: shared secret required in the X-Webhook-Secret header for payment
# webhooks. Leave unset in mock/dev mode (server logs a warning).
WEBHOOK_SECRET=

# Staff accounts created by `npm run seed`
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
KITCHEN_USERNAME=kitchen
KITCHEN_PASSWORD=

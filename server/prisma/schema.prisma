// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// Enums
// ---------------------------------------------------------

enum OrderStatus {
  PENDING     // Received, waiting for kitchen to accept
  PREPARING   // Kitchen is actively preparing the order
  READY       // Preparation done, waiting to be served/picked up
  COMPLETED   // Order has been served to the customer
  CANCELLED   // Order was cancelled
}

enum PaymentStatus {
  PENDING     // Waiting for payment
  PAID        // Payment received
  REFUNDED    // Payment refunded
}

enum PaymentTransactionStatus {
  PENDING     // QR generated, awaiting confirmation
  PAID        // Webhook confirmed
  EXPIRED     // Superseded by a newer payment attempt
  FAILED      // Reserved for future use (real provider failure callback)
}

// ---------------------------------------------------------
// Models
// ---------------------------------------------------------

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  menuItems   MenuItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model MenuItem {
  id          String      @id @default(uuid())
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?
  isAvailable Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Order {
  id            String        @id @default(uuid())
  tableNumber   String        // String allows for values like "T1", "A-12"
  totalAmount   Decimal       @db.Decimal(10, 2)
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  orderItems    OrderItem[]
  payments      Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id])
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2) // Snapshot of price at the time of order
  notes       String?  // E.g., "no onions", "extra spicy"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id          String                   @id @default(uuid())
  orderId     String
  order       Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider    String                   @default("TNG_MOCK")
  referenceId String                   @unique
  amount      Decimal                  @db.Decimal(10, 2)
  status      PaymentTransactionStatus @default(PENDING)
  qrPayload   String
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}
